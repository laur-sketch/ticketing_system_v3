{
  "name": "ticket_system_v3",
  "version": "0.4.1",
  "private": true,
  "scripts": {
    "dev": "node --max-http-header-size=65536 node_modules/next/dist/bin/next dev --webpack",
    "dev:turbo": "next dev --turbopack",
    "build": "node scripts/prisma-generate-retry.cjs && next build",
    "start": "node --max-http-header-size=65536 node_modules/next/dist/bin/next start",
    "start:cpanel": "node --max-http-header-size=65536 server.js",
    "deploy:build": "npm run build && npm run db:migrate:deploy:primary",
    "deploy:pm2": "node scripts/deploy-pm2.cjs",
    "lint": "eslint",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:generate": "node scripts/prisma-generate-retry.cjs",
    "db:migrate": "npm run db:migrate:primary",
    "db:push": "npm run db:push:primary",
    "db:runcheck": "npx tsx scripts/db-runcheck.ts",
    "api:runcheck": "node scripts/api-runcheck.cjs",
    "db:seed": "npx tsx prisma/seed.ts",
    "db:seed:secondary": "npx tsx prisma/seed-secondary.ts",
    "db:populate-tickets": "npx tsx scripts/populate-tickets-date-range.ts",
    "db:backfill-kpi-snapshots": "npx tsx scripts/backfill-kpi-period-snapshots.ts",
    "db:backfill-kpi-snapshots-range": "npx tsx scripts/backfill-kpi-period-snapshots-range.ts",
    "db:apply-kpi-sheet": "npx tsx scripts/apply-kpi-sheet-snapshots.ts",
    "db:apply-kpi-daily": "npx tsx scripts/apply-kpi-daily-snapshots.ts",
    "db:apply-it-salf-daily": "npx tsx scripts/apply-it-salf-daily-csv.ts",
    "db:apply-daily-activity-monitoring": "npx tsx scripts/apply-daily-activity-monitoring-csv.ts",
    "db:apply-helpdesk-csv": "npx tsx scripts/apply-helpdesk-csv.ts",
    "db:merge": "npx tsx scripts/merge-databases.ts",
    "db:merge:hris-incremental": "npx tsx scripts/merge-hris-incremental.ts",
    "db:migrate:phase1": "npx tsx scripts/migrate-phase1-hris-to-merged.ts",
    "db:migrate:phase2": "npx tsx scripts/migrate-phase2-tasks-kpi-to-merged.ts",
    "db:migrate:consolidate": "npx tsx scripts/migrate-consolidate-mergedatabase.ts",
    "db:migrate:primary:snake-case": "npx tsx scripts/migrate-primary-pascal-to-snake.ts --confirm",
    "db:seed:tasks-kpi": "npx tsx scripts/seed-primary-tasks-kpi.ts",
    "db:sync:tasks-kpi": "npx tsx scripts/sync-primary-tasks-kpi.ts",
    "db:sync:portal-work": "npx tsx scripts/sync-primary-tasks-kpi.ts",
    "db:sync:tasks-kpi:full": "npm run db:seed:tasks-kpi && npm run db:sync:tasks-kpi",
    "db:compute:user-efficiency": "npx tsx scripts/compute-user-efficiency-breakdowns.ts",
    "db:compute:user-efficiency:apply": "npx tsx scripts/compute-user-efficiency-breakdowns.ts --apply",
    "db:migrate:kpi-efficiency": "npx tsx scripts/migrate-kpi-to-efficiency-breakdowns.ts",
    "db:migrate:kpi-efficiency:apply": "npx tsx scripts/migrate-kpi-to-efficiency-breakdowns.ts --apply",
    "db:generate:primary": "prisma generate --schema=prisma/db-primary/schema.prisma",
    "db:generate:secondary": "prisma generate --schema=prisma/db-secondary/schema.prisma",
    "db:generate:auth": "prisma generate --schema=prisma/db-auth/schema.prisma",
    "db:generate:all": "npm run db:generate:primary && npm run db:generate:secondary && npm run db:generate:auth",
    "db:push:primary": "prisma db push --schema=prisma/db-primary/schema.prisma",
    "db:push:secondary": "prisma db push --schema=prisma/db-secondary/schema.prisma",
    "db:push:auth": "prisma db push --schema=prisma/db-auth/schema.prisma",
    "db:push:all": "npm run db:push:primary && npm run db:push:secondary && npm run db:push:auth",
    "db:migrate:deploy:primary": "prisma migrate deploy --schema=prisma/db-primary/schema.prisma",
    "db:migrate:deploy:secondary": "prisma migrate deploy --schema=prisma/db-secondary/schema.prisma",
    "db:migrate:deploy:auth": "prisma migrate deploy --schema=prisma/db-auth/schema.prisma",
    "db:migrate:deploy:all": "npm run db:migrate:deploy:primary && npm run db:migrate:deploy:secondary && npm run db:migrate:deploy:auth",
    "db:migrate:primary": "prisma migrate dev --schema=prisma/db-primary/schema.prisma",
    "db:migrate:secondary": "prisma migrate dev --schema=prisma/db-secondary/schema.prisma",
    "db:migrate:auth": "prisma migrate dev --schema=prisma/db-auth/schema.prisma",
    "db:migrate:all": "npm run db:migrate:primary && npm run db:migrate:secondary && npm run db:migrate:auth",
    "db:studio:primary": "prisma studio --schema=prisma/db-primary/schema.prisma",
    "db:studio:secondary": "prisma studio --schema=prisma/db-secondary/schema.prisma",
    "db:studio:auth": "prisma studio --schema=prisma/db-auth/schema.prisma",
    "db:migrate:portal-to-auth": "npx tsx scripts/migrate-portal-to-auth-db.ts",
    "db:seed:auth-role-mappings": "npx tsx scripts/seed-auth-role-mappings.ts",
    "db:sync:hris-portal": "npx tsx scripts/sync-hris-portal-profiles.ts",
    "db:sync:hris-portal:incremental": "npx tsx scripts/sync-hris-portal-incremental.ts",
    "db:sync:hris-clockins": "npx tsx scripts/sync-hris-clockins.ts",
    "db:reset:passwords": "npx tsx scripts/reset-all-login-passwords.ts --confirm aci12345",
    "db:import:restore": "npx tsx scripts/import-from-restore-db.ts --confirm && npx tsx scripts/link-portal-staff-after-import.ts && npm run db:reset:passwords",
    "db:import:july-backup": "npx tsx scripts/import-ticketing-backup.ts --confirm && npm run db:fix:logins",
    "db:fix:logins": "npx tsx scripts/fix-all-login-accounts.ts && npx tsx scripts/reconcile-portal-with-merged-users.ts",
    "db:reconcile:merged-users": "npx tsx scripts/reconcile-portal-with-merged-users.ts",
    "db:sync:portal-merged": "npx tsx scripts/sync-portal-to-merged-users.ts --apply",
    "db:sync:portal-merged:dry": "npx tsx scripts/sync-portal-to-merged-users.ts",
    "db:promote:hris-personnel": "npx tsx scripts/promote-hris-personnel.ts --apply",
    "db:promote:hris-personnel:dry": "npx tsx scripts/promote-hris-personnel.ts",
    "db:merge:hris-portal-credentials": "npm run db:merge:hris-incremental && npm run db:seed:auth-role-mappings && npm run db:reconcile:merged-users && npm run db:sync:merged-roles",
    "db:sync:merged-roles": "npx tsx scripts/sync-merged-roles.ts",
    "db:transfer:portal-work": "npx tsx scripts/transfer-portal-work-to-hris-users.ts",
    "db:merge:legacy-conflicts": "npx tsx scripts/merge-legacy-conflict-accounts.ts",
    "db:adopt:merged-credentials": "npx tsx scripts/adopt-merged-credentials.ts",
    "db:update:workspace-emails": "npx tsx scripts/update-merged-emails-from-workspace-csv.ts",
    "db:merge:source-provenance": "powershell -NoProfile -Command \"Get-Content -Raw scripts/merge-database-source-provenance.sql | & 'C:/Program Files/MySQL/MySQL Server 8.0/bin/mysql.exe' -u root -proot\"",
    "postinstall": "node scripts/prisma-generate-retry.cjs",
    "pm2:start": "node scripts/server-ctl.cjs start",
    "pm2:stop": "node scripts/server-ctl.cjs stop",
    "pm2:restart": "node scripts/server-ctl.cjs restart",
    "pm2:reload": "node scripts/server-ctl.cjs restart",
    "pm2:logs": "powershell -NoProfile -Command \"Get-Content -Path logs/server-out.log,logs/server-error.log -Wait -Tail 50\"",
    "pm2:status": "node scripts/server-ctl.cjs status",
    "pm2:save": "node -e \"console.log('No PM2 save needed on Windows (using server-ctl).')\"",
    "start:pm2": "node scripts/server-ctl.cjs start",
    "docs:pdf": "node scripts/generate-docs-pdf.cjs",
    "docs:flowchart": "npx mmdc -i docs/flowcharts/ticket-system-v3-main-flow.mmd -o docs/flowcharts/ticket-system-v3-main-flow.svg -b transparent && npx mmdc -i docs/flowcharts/ticket-system-v3-main-flow.mmd -o docs/flowcharts/ticket-system-v3-main-flow.png -w 2000 -b white"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "@radix-ui/react-avatar": "^1.1.12",
    "@radix-ui/react-slot": "^1.2.5",
    "@radix-ui/react-tabs": "^1.1.14",
    "bcryptjs": "^3.0.3",
    "class-variance-authority": "^0.7.1",
    "framer-motion": "^12.40.0",
    "lucide-react": "^1.8.0",
    "luxon": "^3.7.2",
    "next": "^16.2.9",
    "next-auth": "^4.24.14",
    "nodemailer": "^9.0.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "socket.io": "^4.8.3",
    "socket.io-client": "^4.8.3"
  },
  "devDependencies": {
    "@mermaid-js/mermaid-cli": "^11.15.0",
    "@tailwindcss/postcss": "^4",
    "@types/bcryptjs": "^2.4.6",
    "@types/luxon": "^3.7.1",
    "@types/node": "^20",
    "@types/nodemailer": "^8.0.0",
    "@types/pg": "^8.20.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "^16.2.9",
    "marked": "^18.0.5",
    "pg": "^8.22.0",
    "pm2": "^7.0.1",
    "prisma": "^5.22.0",
    "puppeteer": "^24.42.0",
    "tailwindcss": "^4",
    "tsx": "^4.22.4",
    "typescript": "^5",
    "vitest": "^4.1.9"
  },
  "overrides": {
    "esbuild": "^0.28.1",
    "postcss": "^8.5.10",
    "uuid": "^11.1.1",
    "ws": "^8.21.0",
    "js-yaml": "^4.2.0"
  }
}
