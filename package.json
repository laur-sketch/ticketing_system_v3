{
  "name": "ticket_system_v3",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "node --max-http-header-size=65536 node_modules/next/dist/bin/next dev --webpack",
    "dev:turbo": "next dev --turbopack",
    "build": "node scripts/prisma-generate-retry.cjs && next build",
    "start": "node --max-http-header-size=65536 node_modules/next/dist/bin/next start",
    "start:cpanel": "node --max-http-header-size=65536 server.js",
    "deploy:build": "npm run build && npx prisma migrate deploy",
    "deploy:pm2": "node scripts/deploy-pm2.cjs",
    "lint": "eslint",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:generate": "node scripts/prisma-generate-retry.cjs",
    "db:migrate": "prisma migrate dev",
    "db:push": "prisma db push",
    "db:runcheck": "npx tsx scripts/db-runcheck.ts",
    "api:runcheck": "node scripts/api-runcheck.cjs",
    "db:seed": "prisma db seed",
    "db:populate-tickets": "npx tsx scripts/populate-tickets-date-range.ts",
    "db:backfill-kpi-snapshots": "npx tsx scripts/backfill-kpi-period-snapshots.ts",
    "db:backfill-kpi-snapshots-range": "npx tsx scripts/backfill-kpi-period-snapshots-range.ts",
    "db:apply-kpi-sheet": "npx tsx scripts/apply-kpi-sheet-snapshots.ts",
    "db:apply-kpi-daily": "npx tsx scripts/apply-kpi-daily-snapshots.ts",
    "db:apply-it-salf-daily": "npx tsx scripts/apply-it-salf-daily-csv.ts",
    "db:apply-daily-activity-monitoring": "npx tsx scripts/apply-daily-activity-monitoring-csv.ts",
    "db:apply-helpdesk-csv": "npx tsx scripts/apply-helpdesk-csv.ts",
    "postinstall": "node scripts/prisma-generate-retry.cjs",
    "pm2:start": "node scripts/server-ctl.cjs start",
    "pm2:stop": "node scripts/server-ctl.cjs stop",
    "pm2:restart": "node scripts/server-ctl.cjs restart",
    "pm2:reload": "node scripts/server-ctl.cjs restart",
    "pm2:logs": "powershell -NoProfile -Command \"Get-Content -Path logs/server-out.log,logs/server-error.log -Wait -Tail 50\"",
    "pm2:status": "node scripts/server-ctl.cjs status",
    "pm2:save": "node -e \"console.log('No PM2 save needed on Windows (using server-ctl).')\"",
    "start:pm2": "node scripts/server-ctl.cjs start",
    "docs:pdf": "node scripts/generate-docs-pdf.cjs",
    "docs:flowchart": "npx mmdc -i docs/flowcharts/ticket-system-v3-main-flow.mmd -o docs/flowcharts/ticket-system-v3-main-flow.svg -b transparent && npx mmdc -i docs/flowcharts/ticket-system-v3-main-flow.mmd -o docs/flowcharts/ticket-system-v3-main-flow.png -w 2000 -b white"
  },
  "prisma": {
    "seed": "npx tsx prisma/seed.ts"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "@radix-ui/react-avatar": "^1.1.12",
    "@radix-ui/react-slot": "^1.2.5",
    "@radix-ui/react-tabs": "^1.1.14",
    "bcryptjs": "^3.0.3",
    "class-variance-authority": "^0.7.1",
    "framer-motion": "^12.40.0",
    "lucide-react": "^1.8.0",
    "luxon": "^3.7.2",
    "next": "^16.2.9",
    "next-auth": "^4.24.14",
    "nodemailer": "^9.0.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "socket.io": "^4.8.3",
    "socket.io-client": "^4.8.3"
  },
  "devDependencies": {
    "@mermaid-js/mermaid-cli": "^11.14.0",
    "@tailwindcss/postcss": "^4",
    "@types/bcryptjs": "^2.4.6",
    "@types/luxon": "^3.7.1",
    "@types/node": "^20",
    "@types/nodemailer": "^8.0.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.4",
    "marked": "^18.0.5",
    "pm2": "^7.0.1",
    "prisma": "^5.22.0",
    "puppeteer": "^24.42.0",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "typescript": "^5",
    "vitest": "^4.1.8"
  },
  "overrides": {
    "esbuild": "^0.28.1",
    "postcss": "^8.5.10",
    "uuid": "^11.1.1",
    "ws": "^8.20.1",
    "js-yaml": "^4.2.0"
  }
}
