[TEMPLATE]
# ── Databases (Native local installs — Docker no longer required) ──────────────

# Primary: Native PostgreSQL (default port 5432).
#   Create the database:  CREATE DATABASE ticket_system_v3_DEV;
#   Update user/password to match your local install.
DATABASE_URL_PRIMARY="postgresql://postgres:YOUR_PASSWORD@localhost:5432/ticket_system_v3_DEV?schema=public"
# Legacy alias (same value) — remove once original prisma/schema.prisma is migrated away.
DATABASE_URL="postgresql://postgres:YOUR_PASSWORD@localhost:5432/ticket_system_v3_DEV?schema=public"

# Secondary: MySQL mergeddatabase-dev (HRIS + attendance + ticketing KPI/task ETL).
#   Demo environment: use mergeddatabase-demo and run npm run db:merge:hris-incremental
#   1. Run:  mysql -u root -p < scripts/create-merged-db-user.sql
#   2. Replace CHANGE_ME_merge_app_password with a strong secret.
#   3. Refresh ETL data: npm run db:merge  (full) or npm run db:merge:hris-incremental (recent HRIS only)
DATABASE_URL_SECONDARY="mysql://merge_app:CHANGE_ME_merge_app_password@localhost:3306/mergeddatabase-dev"
# Used by npm run db:sync:tasks-kpi and npm run db:merge (needs INSERT/DELETE).
DATABASE_URL_SECONDARY_SYNC="mysql://root:YOUR_PASSWORD@localhost:3306/mergeddatabase-dev"

# Incremental HRIS merge (scripts/merge-hris-incremental.ts) — optional overrides:
# HRIS_MERGE_SOURCE_DB="hrisdemo"
# HRIS_MERGE_TARGET_DB="mergeddatabase-demo"
# HRIS_MERGE_SOURCE_TAG="hrisdemo"
# HRIS_MERGE_LOOKBACK_DAYS="90"
# HRIS → mergedatabase (Phase 1 consolidation):
# HRIS_MERGE_SOURCE_DB=hrisdemo
# HRIS_MERGE_TARGET_DB=mergedatabase-demo
# npx tsx scripts/migrate-phase1-hris-to-merged.ts --apply --link-portal
# Full consolidation (Phase 1 + 2): npx tsx scripts/migrate-consolidate-mergedatabase.ts --apply --link-portal
# See docs/MERGEDATABASE_CONSOLIDATION.md
# TICKETING_MERGE_SOURCE_TAG="ticketing_system"
# Merge HRIS users into portal + auth (credentials stay in merged_users):
# npm run db:merge:hris-portal-credentials
# Refresh HRIS roles → merged_users → portal_accounts (after HRIS role changes):
# npm run db:sync:merged-roles
# Credential SoT for password login (default: merged_users).
#   merged  → authenticate against mergeddatabase users; portal_accounts are profiles only
#   portal  → legacy mode using portal_accounts.password_hash first
# PORTAL_CREDENTIALS_SOURCE=merged
# PORTAL_MERGE_SOURCE_TAG=portal_ticketing
# Sync portal → merged_users: npx tsx scripts/sync-portal-to-merged-users.ts --apply
# Adopt merged credentials + clear portal password conflicts:
#   npx tsx scripts/adopt-merged-credentials.ts --apply
# Persistent Task KPI overall-efficiency rollups live in MySQL mergedatabase:
#   npm run db:migrate:kpi-efficiency:apply   # from KPI snapshots → merged_user_efficiency_*
#   npm run db:compute:user-efficiency:apply  # recent windows
#   GET /api/admin/efficiency?mode=leaderboard&periodKey=2026-07&frequency=MONTHLY
# Ticket activity + ticket metrics stay in PostgreSQL primary only.
# Task activities + user efficiencies stay in mergedatabase-demo (MySQL).
# Sync portal work (tasks + KPIs only; tickets stay in primary PG) → mergedatabase-demo:
# npm run db:sync:tasks-kpi
# Ongoing job: POST /api/jobs/sync-portal-merged (x-internal-job-key)
# npx tsx scripts/transfer-portal-work-to-hris-users.ts          # dry run
# npx tsx scripts/transfer-portal-work-to-hris-users.ts --apply

# Auth: dedicated PostgreSQL for OAuth identities (linked to portal_accounts by email/id).
#   Create the database:  CREATE DATABASE ticketing_auth_dev;
DATABASE_URL_AUTH="postgresql://postgres:YOUR_PASSWORD@localhost:5432/ticketing_auth_dev?schema=public"

# ── App ────────────────────────────────────────────────────────────────────────

# Public site URL (no trailing slash). Used for OAuth redirect_uri base and email links.
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="replace-with-a-long-random-string"
# Dev only: set to 1 to keep NEXTAUTH_URL as-is when hostname is not localhost (e.g. ngrok).
# NEXTAUTH_URL_DEV_STICKY="1"

# ── Google Sign-In ─────────────────────────────────────────────────────────────
# Create a "Web application" OAuth client. Authorized JavaScript origins:
#   {NEXTAUTH_URL}     e.g. https://your.domain
# Authorized redirect URIs (must match exactly):
#   {NEXTAUTH_URL}/api/auth/callback/google
GOOGLE_CLIENT_ID="your-google-client-id"
GOOGLE_CLIENT_SECRET="your-google-client-secret"

# ── Role Bootstrap ─────────────────────────────────────────────────────────────
ADMIN_EMAILS="admin@example.com"
AGENT_EMAILS="agent1@example.com,agent2@example.com"

# ── Brevo SMTP ─────────────────────────────────────────────────────────────────
APP_BASE_URL="http://localhost:3000"
BREVO_SMTP_HOST="smtp-relay.brevo.com"
BREVO_SMTP_PORT="587"
BREVO_SMTP_USER=""
BREVO_SMTP_PASS=""
BREVO_FROM_EMAIL="no-reply@example.com"
BREVO_FROM_NAME="Service Desk"

# ── Brand Logo ─────────────────────────────────────────────────────────────────
# Optional custom brand logo absolute path on server/host machine.
# On Windows use forward slashes (C:/assets/logo.png) so \t \n are not read as escapes.
# Or add public/brand/logo.png (or .webp / .jpg) and leave this empty.
BRAND_LOGO_PATH=""
