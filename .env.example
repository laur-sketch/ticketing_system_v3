[TEMPLATE]
# ── Databases (Native local installs — Docker no longer required) ──────────────

# Primary: Native PostgreSQL (default port 5432).
#   Create the database:  CREATE DATABASE ticket_system_v3_DEV;
#   Update user/password to match your local install.
DATABASE_URL_PRIMARY="postgresql://postgres:YOUR_PASSWORD@localhost:5432/ticket_system_v3_DEV?schema=public"
# Legacy alias (same value) — remove once original prisma/schema.prisma is migrated away.
DATABASE_URL="postgresql://postgres:YOUR_PASSWORD@localhost:5432/ticket_system_v3_DEV?schema=public"

# Secondary: MySQL mergeddatabase-dev (HRIS + attendance + ticketing KPI/task ETL).
#   1. Run:  mysql -u root -p < scripts/create-merged-db-user.sql
#   2. Replace CHANGE_ME_merge_app_password with a strong secret.
#   3. Refresh ETL data: npm run db:merge
DATABASE_URL_SECONDARY="mysql://merge_app:CHANGE_ME_merge_app_password@localhost:3306/mergeddatabase-dev"
# Used by npm run db:sync:tasks-kpi and npm run db:merge (needs INSERT/DELETE).
DATABASE_URL_SECONDARY_SYNC="mysql://root:YOUR_PASSWORD@localhost:3306/mergeddatabase-dev"

# Auth: dedicated PostgreSQL for OAuth identities (linked to portal_accounts by email/id).
#   Create the database:  CREATE DATABASE ticketing_auth_dev;
DATABASE_URL_AUTH="postgresql://postgres:YOUR_PASSWORD@localhost:5432/ticketing_auth_dev?schema=public"

# ── App ────────────────────────────────────────────────────────────────────────

# Public site URL (no trailing slash). Used for OAuth redirect_uri base and email links.
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="replace-with-a-long-random-string"
# Dev only: set to 1 to keep NEXTAUTH_URL as-is when hostname is not localhost (e.g. ngrok).
# NEXTAUTH_URL_DEV_STICKY="1"

# ── Google Sign-In ─────────────────────────────────────────────────────────────
# Create a "Web application" OAuth client. Authorized JavaScript origins:
#   {NEXTAUTH_URL}     e.g. https://your.domain
# Authorized redirect URIs (must match exactly):
#   {NEXTAUTH_URL}/api/auth/callback/google
GOOGLE_CLIENT_ID="your-google-client-id"
GOOGLE_CLIENT_SECRET="your-google-client-secret"

# ── Role Bootstrap ─────────────────────────────────────────────────────────────
ADMIN_EMAILS="admin@example.com"
AGENT_EMAILS="agent1@example.com,agent2@example.com"

# ── Brevo SMTP ─────────────────────────────────────────────────────────────────
APP_BASE_URL="http://localhost:3000"
BREVO_SMTP_HOST="smtp-relay.brevo.com"
BREVO_SMTP_PORT="587"
BREVO_SMTP_USER=""
BREVO_SMTP_PASS=""
BREVO_FROM_EMAIL="no-reply@example.com"
BREVO_FROM_NAME="Service Desk"

# ── Brand Logo ─────────────────────────────────────────────────────────────────
# Optional custom brand logo absolute path on server/host machine.
# On Windows use forward slashes (C:/assets/logo.png) so \t \n are not read as escapes.
# Or add public/brand/logo.png (or .webp / .jpg) and leave this empty.
BRAND_LOGO_PATH=""
