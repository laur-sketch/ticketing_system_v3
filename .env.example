DATABASE_URL="postgresql://tickets:tickets@localhost:5432/ticket_system?schema=public"
# Public site URL (no trailing slash). Used for OAuth redirect_uri base and email links.
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="replace-with-a-long-random-string"

# Google Sign-In: create a "Web application" OAuth client. Authorized JavaScript origins:
#   {NEXTAUTH_URL}     e.g. https://your.domain
# Authorized redirect URIs (must match exactly):
#   {NEXTAUTH_URL}/api/auth/callback/google
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Optional role bootstrap by email (comma-separated)
ADMIN_EMAILS="admin@example.com"
AGENT_EMAILS="agent1@example.com,agent2@example.com"

# Brevo SMTP (for resolved ticket confirmation + mandatory rating email)
APP_BASE_URL="http://localhost:3000"
BREVO_SMTP_HOST="smtp-relay.brevo.com"
BREVO_SMTP_PORT="587"
BREVO_SMTP_USER=""
BREVO_SMTP_PASS=""
BREVO_FROM_EMAIL="no-reply@example.com"
BREVO_FROM_NAME="Service Desk"

# Optional custom brand logo absolute path on server/host machine
# Example (Windows): C:\assets\agc-logo.png
BRAND_LOGO_PATH=""
