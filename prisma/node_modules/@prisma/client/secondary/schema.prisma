generator client {
  provider = "prisma-client-js"
  output   = "../node_modules/@prisma/client/secondary"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL_SECONDARY")
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum TaskStatus {
  BACKLOG
  TODO
  IN_PROGRESS
  REVIEW
  DONE
  CANCELLED
}

model Board {
  id          String   @id @default(cuid())
  title       String   @map("title")
  description String?  @map("description") @db.Text
  color       String   @default("#6366f1") @map("color")
  sortOrder   Int      @default(0) @map("sort_order")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  tasks       Task[]

  @@index([sortOrder])
  @@map("boards")
}

model Task {
  id          String       @id @default(cuid())
  title       String       @map("title")
  description String?      @map("description") @db.Text
  status      TaskStatus   @default(BACKLOG) @map("status")
  priority    TaskPriority @default(MEDIUM) @map("priority")
  sortOrder   Int          @default(0) @map("sort_order")
  boardId     String       @map("board_id")
  board       Board        @relation(fields: [boardId], references: [id], onDelete: Cascade)
  dueAt       DateTime?    @map("due_at")
  completedAt DateTime?    @map("completed_at")

  // Logical cross-database references (no @relation constraint)
  createdById    String  @map("created_by_id")
  assignedUserId Int?    @map("assigned_user_id")
  ticketId       String? @map("ticket_id")

  createdAt  DateTime    @default(now()) @map("created_at")
  updatedAt  DateTime    @updatedAt @map("updated_at")
  subtasks   Subtask[]
  kpiMetrics KpiMetric[]

  @@index([boardId, sortOrder])
  @@index([assignedUserId])
  @@index([ticketId])
  @@index([status, dueAt])
  @@map("tasks")
}

model Subtask {
  id        String   @id @default(cuid())
  title     String   @map("title")
  done      Boolean  @default(false) @map("done")
  sortOrder Int      @default(0) @map("sort_order")
  taskId    String   @map("task_id")
  task      Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([taskId, sortOrder])
  @@map("subtasks")
}

model KpiMetric {
  id          String   @id @default(cuid())
  taskId      String   @map("task_id")
  task        Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  metricName  String   @map("metric_name")
  metricValue Float?   @map("metric_value")
  targetValue Float?   @map("target_value")
  unit        String?  @map("unit")
  recordedAt  DateTime @default(now()) @map("recorded_at")
  notes       String?  @map("notes") @db.Text
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@index([taskId])
  @@index([metricName, recordedAt])
  @@map("kpi_metrics")
}
