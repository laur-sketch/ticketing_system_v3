# Copy this file to .env.restore (same folder) and set a DATABASE_URL that works in pgAdmin.
# .env.restore is gitignored. Use 127.0.0.1 if localhost fails. URL-encode special chars in the password (e.g. @ -> %40).
# Re-run from scratch: scripts/restore-ticketing-system-v3.ps1 -RecreateDatabase
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/postgres?schema=public"
